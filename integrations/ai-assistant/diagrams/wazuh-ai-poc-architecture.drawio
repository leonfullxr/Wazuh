 loop, lane 2 IR&lt;br&gt;tens of seconds · the expensive path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="950" y="330" width="300" height="110" as="geometry"/></mxCell><mxCell id="wai18-10" value="Stage 3 · depth lane&lt;br&gt;AirLLM 70B+ · batch, overnight&lt;br&gt;never interactive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6E5;strokeColor=#B7962E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1300" y="330" width="300" height="110" as="geometry"/></mxCell><mxCell id="wai18-11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.8;fontSize=10;fontStyle=1;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#232F3E;dashed=0;" edge="1" parent="1" source="wai18-3" target="wai18-5"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-12" value="no template ≥ threshold" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.8;fontSize=10;fontStyle=1;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#5A6B86;dashed=1;" edge="1" parent="1" source="wai18-5" target="wai18-7"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-13" value="router escalates" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.8;fontSize=10;fontStyle=1;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#5A6B86;dashed=1;" edge="1" parent="1" source="wai18-7" target="wai18-9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-14" value="on request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;htm