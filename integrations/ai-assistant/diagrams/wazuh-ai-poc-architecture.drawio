ight="24" as="geometry"/></mxCell><mxCell id="blog5-5" value="least verifiable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;dashed=0;fontColor=#8E2130;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacing=8;arcSize=10;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="10" y="640" width="200" height="24" as="geometry"/></mxCell><mxCell id="blog5-6" value="&lt;b&gt;Lane 0 · Recognition&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#5A6B86'&gt;embedding match → pre-approved typed template&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=12;fontStyle=0;align=center;verticalAlign=middle;spacing=8;arcSize=10;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="120" y="140" width="400" height="95" as="geometry"/></mxCell><mxCell id="blog5-7" value="&lt;b&gt;verifiable BY CONSTRUCTION&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#2E7D32'&gt;no model involved · deterministic render&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF6EC;strokeColor=#2E7D32;dashed=0;fontColor=#232F3E;fontSize=12;fontStyle=0;align=center;verticalAlign=middle;spacing=8;arcSize=10;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="560" y="140" width="430" height="95" as="geometry"/></mxCell><mxCell id="blog5-8" value="the frequent questions · ~40 ms · zero tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;dashed=0;fontColor=#5A6B86;fontSize=12;fontStyle=0;align=left;verticalAlign=middle;spacing=8;arcSize=10;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="1030" y="140" width="470" height="95" as="geometry"/></mxCell><mxCell id="blog5-9" value="&lt;b&gt;Lane 1 · Typed tools&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#5A6B86'&gt;model picks from a small catalog · params schema-validated&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;font