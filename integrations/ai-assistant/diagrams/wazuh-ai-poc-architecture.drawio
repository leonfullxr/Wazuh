" y="390" width="430" height="95" as="geometry"/></mxCell><mxCell id="blog5-14" value="the long tail the fixed catalog cannot express" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;dashed=0;fontColor=#5A6B86;fontSize=12;fontStyle=0;align=left;verticalAlign=middle;spacing=8;arcSize=10;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="1030" y="390" width="470" height="95" as="geometry"/></mxCell><mxCell id="blog5-15" value="&lt;b&gt;Lane 3 · Raw generation&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#5A6B86'&gt;model writes datastore queries directly&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=12;fontStyle=0;align=center;verticalAlign=middle;spacing=8;arcSize=10;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="120" y="515" width="400" height="95" as="geometry"/></mxCell><mxCell id="blog5-16" value="&lt;b&gt;verifiable BY GATE ONLY&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#8E2130'&gt;parse · allowlist · scripts banned · dry-run&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEF0;strokeColor=#DD344C;dashed=0;fontColor=#232F3E;fontSize=12;fontStyle=0;align=center;verticalAlign=middle;spacing=8;arcSize=10;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="560" y="515" width="430" height="95" as="geometry"/></mxCell><mxCell id="blog5-17" value="exists as a concept - stays OFF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;dashed=0;fontColor=#5A6B86;fontSize=12;fontStyle=0;align=left;verticalAlign=middle;spacing=8;arcSize=10;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="1030" y="515" width="470" height="95" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="blog6" name="6 · Injection defense"><mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1660" pageHeight="700