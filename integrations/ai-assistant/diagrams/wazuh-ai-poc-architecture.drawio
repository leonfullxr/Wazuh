<mxfile host="app.diagrams.net" type="device" version="24.7.17"><diagram id="wai15" name="1 · Local PoC harness"><mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1720" pageHeight="1060" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="wai15-1" value="Self-hosted test harness - everything local, inference pluggable" style="text;html=1;fontSize=20;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="14" width="1100" height="30" as="geometry"/></mxCell><mxCell id="wai15-2" value="This PoC on one machine: real Wazuh, real OIDC, real JWT auth domain · only inference may leave the box, and even that is optional" style="text;html=1;fontSize=11;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="46" width="1200" height="20" as="geometry"/></mxCell><mxCell id="wai15-3" value="Analyst&lt;br&gt;(analyst1)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;aspect=fixed;shape=mxgraph.aws4.users;" vertex="1" parent="1"><mxGeometry x="60" y="120" width="60" height="60" as="geometry"/></mxCell><mxCell id="wai15-4" value="Your machine · docker network single-node_default" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#5A6B86;dashed=1;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="250" width="1200" height="740" as="geometry"/></mxCell><mxCell id="wai15-5" value="Keycloak :8085&lt;br&gt;realm wazuh-poc&lt;br&gt;customer IdP stand-in" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="80" y="320" width="200" height="90" as="geometry"/></mxCell><mxCell id="wai15-6" value="n8n :5678&lt;br&gt;edge only (D28)&lt;br&gt;chat in, answer out" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="330" y="320" width="170" height="90" as="geometry"/></mxCell><mxCell id="wai15-7" value="auth-shim :8081&lt;br&gt;verifies OIDC vs JWKS · checks wazuh_ai_analyst · mints turn JWT ≤10 min (D30)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="560" y="310" width="230" height="110" as="geometry"/></mxCell><mxCell id="wai15-8" value="tool service :8080 - the core (D28)&lt;br&gt;&lt;br&gt;agent loop · typed tools + lane 2 · Query IR → OpenSearch DSL · 4 veracity checks · citation verification · admission · JSON audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#5A6B86;dashed=1;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="560" y="480" width="560" height="150" as="geometry"/></mxCell><mxCell id="wai15-9" value="ollama :11434&lt;br&gt;compose profile 'ollama'&lt;br&gt;local models (qwen2.5 · llama3.x)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=1;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="860" y="310" width="250" height="100" as="geometry"/></mxCell><mxCell id="wai15-10" value="wazuh-docker single-node (official, pinned tag)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#ED7100;dashed=1;fontColor=#ED7100;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="70" y="680" width="570" height="290" as="geometry"/></mxCell><mxCell id="wai15-11" value="wazuh.manager&lt;br&gt;1514 · 55000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="100" y="750" width="150" height="80" as="geometry"/></mxCell><mxCell id="wai15-12" value="wazuh.indexer :9200&lt;br&gt;JWT auth domain +&lt;br&gt;wazuh_ai_analyst_role" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elasticsearch_service;" vertex="1" parent="1"><mxGeometry x="310" y="740" width="58" height="58" as="geometry"/></mxCell><mxCell id="wai15-13" value="wazuh.dashboard&lt;br&gt;:443" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="460" y="750" width="160" height="80" as="geometry"/></mxCell><mxCell id="wai15-14" value="Amazon Bedrock&lt;br&gt;(default backend)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#01A88D;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.bedrock;" vertex="1" parent="1"><mxGeometry x="1420" y="330" width="58" height="58" as="geometry"/></mxCell><mxCell id="wai15-15" value="Groq · LiteLLM · vLLM · LM Studio&lt;br&gt;any OpenAI-compatible endpoint&lt;br&gt;(cloud or elsewhere on your LAN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=1;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1330" y="480" width="300" height="100" as="geometry"/></mxCell><mxCell id="wai15-16" value="1 · SSO login (lab: password grant)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai15-3" target="wai15-5"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai15-17" value="2 · chat" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai15-3" target="wai15-6"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai15-18" value="3 · OIDC token → exchange" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai15-6" target="wai15-7"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai15-19" value="JWKS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#5A6B86;dashed=1;" edge="1" parent="1" source="wai15-5" target="wai15-7"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai15-20" value="4 · turn JWT" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#0B7285;dashed=0;" edge="1" parent="1" source="wai15-7" target="wai15-6"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai15-21" value="5 · question + turn JWT" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#0B7285;dashed=0;" edge="1" parent="1" source="wai15-6" target="wai15-8"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai15-22" value="6 · queries AS THE ANALYST&lt;br&gt;(JWT auth domain, D11)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#0B7285;dashed=0;" edge="1" parent="1" source="wai15-8" target="wai15-12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai15-23" value="provider=bedrock" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#01A88D;dashed=0;" edge="1" parent="1" source="wai15-8" target="wai15-14"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai15-24" value="provider=openai (local)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#2E7D32;dashed=1;" edge="1" parent="1" source="wai15-8" target="wai15-9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai15-25" value="provider=openai (remote)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#B7962E;dashed=1;" edge="1" parent="1" source="wai15-8" target="wai15-15"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai15-26" value="Bring-up order (Makefile):&lt;br&gt;make keys → wazuh → securityconfig → poc → seed → evals. The golden set exercises this whole picture end to end and exits nonzero on any honesty failure." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1330" y="640" width="350" height="150" as="geometry"/></mxCell><mxCell id="wai15-27" value="Key custody (D30): the JWT private key is mounted ONLY into the auth shim. The tool service and the indexer hold the public key and can only verify - the reasoning core cannot forge identities." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEF0;strokeColor=#DD344C;dashed=0;fontColor=#8E2130;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1330" y="810" width="350" height="130" as="geometry"/></mxCell><mxCell id="wai15-28" value="Ports and roles mirror production: the indexer is the same OpenSearch fork a tenant runs, the securityconfig additions are the same YAML the fleet pipeline would template, and n8n stays a thin edge. What is missing is the AWS wrapper: IRSA, inference profiles, PrivateLink, NetworkPolicy (a later kind-based stage)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="660" y="680" width="560" height="130" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="wai16" name="2 · Local turn data flow"><mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1720" pageHeight="900" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="wai16-1" value="One question through the harness - identity chain first, veracity pipeline on every tool call" style="text;html=1;fontSize=20;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="14" width="1100" height="30" as="geometry"/></mxCell><mxCell id="wai16-2" value="The same flow for every inference backend · only the model endpoint behind step 6 changes (page 3) · whether a model runs at all is the cascade on page 4" style="text;html=1;fontSize=11;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="46" width="1200" height="20" as="geometry"/></mxCell><mxCell id="wai16-3" value="Analyst authenticates at Keycloak&lt;br&gt;(lab: password grant for analyst1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="60" y="160" width="260" height="110" as="geometry"/></mxCell><mxCell id="wai16-4" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="46" y="146" width="28" height="28" as="geometry"/></mxCell><mxCell id="wai16-5" value="Shim verifies the OIDC token vs the IdP JWKS · requires the wazuh_ai_analyst role (D18)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="380" y="160" width="260" height="110" as="geometry"/></mxCell><mxCell id="wai16-6" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="366" y="146" width="28" height="28" as="geometry"/></mxCell><mxCell id="wai16-7" value="Shim mints the turn JWT · dual audience · ≤10 min · tenant claim from config, never from input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="700" y="160" width="260" height="110" as="geometry"/></mxCell><mxCell id="wai16-8" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="686" y="146" width="28" height="28" as="geometry"/></mxCell><mxCell id="wai16-9" value="Tool service verifies: signature · iss · aud · exp · tenant · role. Verify-only: no mint key here" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1020" y="160" width="260" height="110" as="geometry"/></mxCell><mxCell id="wai16-10" value="4" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1006" y="146" width="28" height="28" as="geometry"/></mxCell><mxCell id="wai16-11" value="Admission (D14): one stream per user · per-user rate · tenant semaphore around the model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1340" y="160" width="260" height="110" as="geometry"/></mxCell><mxCell id="wai16-12" value="5" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1326" y="146" width="28" height="28" as="geometry"/></mxCell><mxCell id="wai16-13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai16-3" target="wai16-5"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai16-5" target="wai16-7"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-15" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai16-7" target="wai16-9"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-16" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai16-9" target="wai16-11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-17" value="Model picks a typed tool (lane 1) or emits a Query IR (lane 2). Params schema-validated · fields allowlisted · prior turns replayed from the conversation store (conversation_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="60" y="420" width="260" height="110" as="geometry"/></mxCell><mxCell id="wai16-18" value="6" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="46" y="406" width="28" height="28" as="geometry"/></mxCell><mxCell id="wai16-19" value="Veracity pipeline: mapping check → dry-run → execute as the analyst → zero-hit diagnosis (D24)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="380" y="420" width="260" height="110" as="geometry"/></mxCell><mxCell id="wai16-20" value="7" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="366" y="406" width="28" height="28" as="geometry"/></mxCell><mxCell id="wai16-21" value="Evidence: exact datastore total + aggregation buckets + truncated sample, compacted to budget" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="700" y="420" width="260" height="110" as="geometry"/></mxCell><mxCell id="wai16-22" value="8" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="686" y="406" width="28" height="28" as="geometry"/></mxCell><mxCell id="wai16-23" value="Synthesis streams token-by-token · every claim cites [alert:id] / [agg:name] · citations verified against what was retrieved" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1020" y="420" width="260" height="110" as="geometry"/></mxCell><mxCell id="wai16-24" value="9" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1006" y="406" width="28" height="28" as="geometry"/></mxCell><mxCell id="wai16-25" value="Answer + verifiability label + audit event (tool, IR, total, checks) as JSON lines" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1340" y="420" width="260" height="110" as="geometry"/></mxCell><mxCell id="wai16-26" value="10" style="ellipse;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=none;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1326" y="406" width="28" height="28" as="geometry"/></mxCell><mxCell id="wai16-27" value="lane 0: embedding matches a curated template? (D40)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;fontColor=#5B4A12;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1385" y="300" width="170" height="80" as="geometry"/></mxCell><mxCell id="wai16-28" value="Lane 0 hit: the template's typed tool executes directly · deterministic bilingual render · ~40 ms · zero model tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF6EC;strokeColor=#2E7D32;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1000" y="292" width="300" height="96" as="geometry"/></mxCell><mxCell id="wai16-29" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai16-11" target="wai16-27"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-30" value="hit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#2E7D32;dashed=0;" edge="1" parent="1" source="wai16-27" target="wai16-28"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-31" value="no model involved" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#2E7D32;dashed=0;" edge="1" parent="1" source="wai16-28" target="wai16-25"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-32" value="miss (or lane 0 off)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#5A6B86;dashed=1;" edge="1" parent="1" source="wai16-27" target="wai16-17"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-33" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai16-17" target="wai16-19"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-34" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai16-19" target="wai16-21"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-35" value="next tool call (≤ WAI_MAX_TOOL_CALLS)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#5A6B86;dashed=1;" edge="1" parent="1" source="wai16-21" target="wai16-17"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-36" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai16-21" target="wai16-23"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-37" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai16-23" target="wai16-25"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai16-38" value="Counts are structural, not prompted: 'how many' answers come from total_matching or aggregation values the datastore computed, and the sampled list is explicitly truncated so counting it is impossible by construction." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="60" y="620" width="780" height="120" as="geometry"/></mxCell><mxCell id="wai16-39" value="Zero hits are diagnosed, not guessed: the pipeline probes the window and each filter individually, so the answer distinguishes 'no such events (verified: 214 documents in the window, none from db-99)' from 'the query was wrong'." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="880" y="620" width="800" height="120" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="wai17" name="3 · Inference backends &amp; sovereignty"><mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1720" pageHeight="900" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="wai17-1" value="One provider port, three postures - what actually leaves your machine per backend" style="text;html=1;fontSize=20;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="14" width="1100" height="30" as="geometry"/></mxCell><mxCell id="wai17-2" value="WAI_LLM_PROVIDER selects the adapter in llm.py · everything above the port is identical" style="text;html=1;fontSize=11;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="46" width="1200" height="20" as="geometry"/></mxCell><mxCell id="wai17-3" value="Tool service loop&lt;br&gt;&lt;br&gt;speaks the Bedrock Converse shape everywhere · tools · Query IR · veracity pipeline · citation verification · admission · audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#5A6B86;dashed=1;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="150" width="360" height="210" as="geometry"/></mxCell><mxCell id="wai17-4" value="Provider port · llm.py&lt;br&gt;WAI_LLM_PROVIDER = bedrock | openai&lt;br&gt;the openai adapter translates Converse ↔ chat-completions, tool calls included" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="410" width="360" height="130" as="geometry"/></mxCell><mxCell id="wai17-5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai17-3" target="wai17-4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai17-6" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3FAF4;strokeColor=#2E7D32;dashed=1;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="470" y="120" width="1210" height="165" as="geometry"/></mxCell><mxCell id="wai17-7" value="Amazon Bedrock (default)&lt;br&gt;provider=bedrock&lt;br&gt;inference-profile ids from your account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="490" y="140" width="250" height="120" as="geometry"/></mxCell><mxCell id="wai17-8" value="Crosses the boundary: the question + COMPACTED evidence, under AWS no-retention / no-training terms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF6EC;strokeColor=#2E7D32;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="770" y="150" width="430" height="100" as="geometry"/></mxCell><mxCell id="wai17-9" value="Production semantics: the same Converse API you ship · Guardrails attach per invocation (D38) · strongest tool calling · pennies per query" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1230" y="150" width="430" height="100" as="geometry"/></mxCell><mxCell id="wai17-10" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3FAF4;strokeColor=#2E7D32;dashed=1;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="470" y="305" width="1210" height="165" as="geometry"/></mxCell><mxCell id="wai17-11" value="Ollama (local model)&lt;br&gt;provider=openai&lt;br&gt;base url http://ollama:11434/v1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="490" y="325" width="250" height="120" as="geometry"/></mxCell><mxCell id="wai17-12" value="Crosses the boundary: NOTHING - fully air-gapped. Questions and evidence never leave the machine (the strictest sovereignty demo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF6EC;strokeColor=#2E7D32;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="770" y="335" width="430" height="100" as="geometry"/></mxCell><mxCell id="wai17-13" value="Prefer sparse MoE: gpt-oss:20b (14 GB file, 16 GB systems) · qwen3:30b-a3b (19 GB, ~3.3B active) - big-model quality, tool calling · no Guardrails: app-layer checks + golden injection cases carry safety" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6E5;strokeColor=#B7962E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1230" y="335" width="430" height="100" as="geometry"/></mxCell><mxCell id="wai17-14" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF2F4;strokeColor=#DD344C;dashed=1;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="470" y="490" width="1210" height="165" as="geometry"/></mxCell><mxCell id="wai17-15" value="Groq / other OpenAI-compatible cloud&lt;br&gt;provider=openai + url + api key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="490" y="510" width="250" height="120" as="geometry"/></mxCell><mxCell id="wai17-16" value="Crosses the boundary: the question + evidence, under the PROVIDER'S terms - the data-sovereignty tradeoff of hosted inference applies" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEF0;strokeColor=#DD344C;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="770" y="520" width="430" height="100" as="geometry"/></mxCell><mxCell id="wai17-17" value="Runs the same model the golden set targets, so evals grade that exact model on this veracity ladder. For lab and demo use." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEF0;strokeColor=#DD344C;dashed=0;fontColor=#8E2130;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1230" y="520" width="430" height="100" as="geometry"/></mxCell><mxCell id="wai17-18" value="option A" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#2E7D32;dashed=0;" edge="1" parent="1" source="wai17-4" target="wai17-7"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai17-19" value="option B" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#2E7D32;dashed=0;" edge="1" parent="1" source="wai17-4" target="wai17-11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai17-20" value="option C" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#DD344C;dashed=1;" edge="1" parent="1" source="wai17-4" target="wai17-15"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai17-21" value="LiteLLM can front Bedrock itself, which turns backend switching into a base-url change during development - one dial across local and cloud." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="590" width="360" height="130" as="geometry"/></mxCell><mxCell id="wai17-22" value="Memory ladder (D39): quantization → sparse MoE → flash attention + q8_0 KV cache → partial GPU offload → AirLLM layer streaming (70B+ on a 4-8 GB GPU at 0.07-0.7 tok/s: a BATCH depth lane, never interactive). Tiers can split across endpoints: local router + Bedrock or big-local analysis." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="740" width="360" height="150" as="geometry"/></mxCell><mxCell id="wai17-23" value="Switching backends is an .env change plus one docker compose recreate. Nothing above the port moves: same loop, same IR, same veracity checks, same identity chain, same audit. Finish every switch with make evals - the golden set does not care who answered, only whether the answers were true (a model bake-off)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="470" y="690" width="1210" height="110" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="wai18" name="4 · Query cascade (D40/D41)"><mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1720" pageHeight="900" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="wai18-1" value="Recognition before reasoning - each stage only sees what the previous one could not answer" style="text;html=1;fontSize=20;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="14" width="1100" height="30" as="geometry"/></mxCell><mxCell id="wai18-2" value="Lane 0 (D40) removes the model from frequent questions · the evidence cache (D41) removes the query from repeated ones" style="text;html=1;fontSize=11;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="46" width="1200" height="20" as="geometry"/></mxCell><mxCell id="wai18-3" value="Analyst question&lt;br&gt;&lt;br&gt;any surface: SSE chat, sync JSON, n8n edge, alert_id deep link" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="200" width="220" height="130" as="geometry"/></mxCell><mxCell id="wai18-4" value="Stage 0 · lane 0 semantic match&lt;br&gt;&lt;br&gt;embed the question (bge-m3, local) · cosine vs the curated bilingual exemplar corpus · a match ≥ 0.80 executes the template's typed tool&lt;br&gt;&lt;br&gt;~40 ms · zero model tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF6EC;strokeColor=#2E7D32;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="330" y="190" width="300" height="150" as="geometry"/></mxCell><mxCell id="wai18-5" value="Stage 1 · router tier&lt;br&gt;&lt;br&gt;small cheap model (Haiku class or a local 7-8b) answers simple questions with one or two typed tool calls&lt;br&gt;&lt;br&gt;seconds · pennies (or free locally)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="700" y="190" width="300" height="150" as="geometry"/></mxCell><mxCell id="wai18-6" value="Stage 2 · analysis tier&lt;br&gt;&lt;br&gt;full model (Sonnet class or a local sparse MoE) runs the investigation loop, lane 2 Query IR included&lt;br&gt;&lt;br&gt;tens of seconds · the expensive path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=0;align=center;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1070" y="190" width="300" height="150" as="geometry"/></mxCell><mxCell id="wai18-7" value="Stage 3 · depth lane&lt;br&gt;&lt;br&gt;AirLLM layer-streamed 70B+ · batch by design, one hard question overnight · never interactive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6E5;strokeColor=#B7962E;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1440" y="190" width="240" height="150" as="geometry"/></mxCell><mxCell id="wai18-8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai18-3" target="wai18-4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-9" value="no template ≥ threshold" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#5A6B86;dashed=1;" edge="1" parent="1" source="wai18-4" target="wai18-5"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-10" value="router escalates: investigation needed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#5A6B86;dashed=1;" edge="1" parent="1" source="wai18-5" target="wai18-6"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-11" value="explicit request only (second opinion)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#B7962E;dashed=1;" edge="1" parent="1" source="wai18-6" target="wai18-7"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-12" value="Shared veracity pipeline - identical for every stage: field allowlist · IR compiled server-side · mapping check · dry-run · execute as the analyst (turn JWT) · datastore-computed totals · zero-hit diagnosis · citation verification · audit event · verifiability label" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F7FA;strokeColor=#5A6B86;dashed=1;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="330" y="480" width="1350" height="110" as="geometry"/></mxCell><mxCell id="wai18-13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai18-4" target="wai18-12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai18-5" target="wai18-12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-15" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai18-6" target="wai18-12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-16" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.6;fontSize=9;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#545B64;dashed=0;" edge="1" parent="1" source="wai18-7" target="wai18-12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai18-17" value="Evidence cache (D41): identical query plans inside the TTL are served from memory, keyed by a hash of the canonical IR with time bounds floored to the TTL grid. Cached answers disclose served_from_cache. WAI_EVIDENCE_CACHE_TTL, 0 = off." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="480" width="250" height="180" as="geometry"/></mxCell><mxCell id="wai18-18" value="On Bedrock, a lane 0 hit is a zero-token turn: the most frequent questions cost nothing and answer in tens of milliseconds." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF6EC;strokeColor=#2E7D32;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="690" width="250" height="130" as="geometry"/></mxCell><mxCell id="wai18-19" value="One artifact, three jobs: the lane 0 exemplar corpus, the bilingual golden set, and downstream NL-to-query translations converge on the same curated question-to-plan pairs. Every question the fleet answers well becomes a template candidate, and every template is graded by the same golden gate before it ships." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=6;" vertex="1" parent="1"><mxGeometry x="330" y="640" width="1350" height="120" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>