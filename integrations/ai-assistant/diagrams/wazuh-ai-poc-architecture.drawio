="470" height="72" as="geometry"/></mxCell><mxCell id="wai17-8" value="Production semantics: the same Converse API you ship · Guardrails attach per call (D38) · strongest tool calling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=11;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1070" y="144" width="600" height="72" as="geometry"/></mxCell><mxCell id="wai17-9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.8;fontSize=10;fontStyle=1;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#01A88D;dashed=0;exitX=1;exitY=0.15;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="wai17-4" target="wai17-6"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai17-10" value="Ollama&lt;br&gt;local model" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="1"><mxGeometry x="470" y="340" width="60" height="60" as="geometry"/></mxCell><mxCell id="wai17-11" value="Crosses the boundary: NOTHING · fully air-gapped.&lt;br&gt;Question and evidence never leave the machine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF6EC;strokeColor=#2E7D32;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="570" y="334" width="470" height="72" as="geometry"/></mxCell><mxCell id="wai17-12" value="Prefer sparse MoE locally: gpt-oss:20b (16 GB) · qwen3:30b-a3b (~3.3B active) - big-model quality, tool calling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E8;strokeColor=#B7962E;dashed=0;fontColor=#5B4A12;fontSize=11;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1070" y="334" width="600" height="72" as="geometry"/></mxCell><mxCell id="wai17-13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.8;fontSize=10;fontStyle=1;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#2E7D32;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="wai17-4" target="wai17-10"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="wai17-14" value="OpenAI-&lt;br&gt;compatible" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;dashed=1;fontColor=#232F3E;fontSize=9;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="470" y="528" width="60" height="60" as="geometry"/></mxCell><mxCell id="wai17-15" value="Crosses the boundary: question + evidence,&lt;br&gt;under the PROVIDER'S terms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEF0;strokeColor=#DD344C;dashed=0;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="570" y="524" width="470" height="72" as="geometry"/></mxCell><mxCell id="wai17-16" value="Groq · any OpenAI-compatible cloud. Lab and demo use: grade the exact model on the same veracity ladder." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEF0;strokeColor=#DD344C;dashed=0;fontColor=#8E2130;fontSize=11;fontStyle=0;align=left;verticalAlign=top;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1070" y="524" width="600" height="72" as="geometry"/></mxCell><mxCell id="wai17-17" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.8;fontSize=10;fontStyle=1;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;strokeColor=#