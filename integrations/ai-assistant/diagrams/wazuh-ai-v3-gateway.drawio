<mxfile host="app.diagrams.net" type="device" version="24.7.17">
  <diagram id="v3a" name="1 · v3 target: one gateway, N environments">
    <mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1660" pageHeight="1010" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="v1t" value="wazuh-ai v3 — the Dashboard Assistant edge and the multi-environment gateway" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="1500" height="32" as="geometry"/></mxCell>
        <mxCell id="v1s" value="Upstream shape (wazuh/integrations AI_assistant) adopted at the edge · our core replaces its gateway: lanes, IR, four checks, citations, grounded numbers · orange = new in v3 · identity per edge: per-USER on direct surfaces (D11), per-ENVIRONMENT on the connector edge (D42)" style="text;html=1;fontSize=12;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="52" width="1580" height="20" as="geometry"/></mxCell>
        <mxCell id="v1e1" value="Environment A — customer Wazuh (4.8–4.16.x · OpenSearch 2.19.x)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B8354;strokeWidth=2;fontColor=#1B8354;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="520" height="330" as="geometry"/></mxCell>
        <mxCell id="v1e1d" value="Wazuh Dashboard&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;+ assistantDashboards + mlCommonsDashboards (baked image) · assistant.chat.enabled · the analyst chats where they already work&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v1e1"><mxGeometry x="20" y="40" width="230" height="120" as="geometry"/></mxCell>
        <mxCell id="v1e1m" value="ML Commons (in the indexer)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;remote model + conversational agent (max_iteration 1, os_chat root) · conversation memory: conversation_index, last 10 (D45) · HTTP connector holds the env credential, encrypted&lt;br&gt;&lt;b&gt;D53:&lt;/b&gt; a chat &#39;yes&#39;/&#39;confirm&#39; here EXECUTES the pending action under the env principal — dashboard access = authority (Leon&#39;s call); high-risk still target-echoed&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v1e1"><mxGeometry x="270" y="40" width="230" height="150" as="geometry"/></mxCell>
        <mxCell id="v1e1i" value="Wazuh Indexer&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;wazuh-alerts-* · embeddings model in-cluster (C3) · principals: wazuh_ai_analyst_role (per-user JWT, D11) and wazuh_ai_env_reader (read-only, this edge, D42)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v1e1"><mxGeometry x="20" y="180" width="480" height="130" as="geometry"/></mxCell>
        <mxCell id="v1e2" value="Environment B … N — same shape, own credential, own reader principal, own embeddings model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B8354;strokeWidth=2;dashed=1;fontColor=#1B8354;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="460" width="520" height="90" as="geometry"/></mxCell>
        <mxCell id="v1gw" value="wazuh-ai GATEWAY — one deployment for all environments (D43/D44)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=2;fontColor=#232F3E;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=6;" vertex="1" parent="1"><mxGeometry x="660" y="100" width="620" height="620" as="geometry"/></mxCell>
        <mxCell id="v1gs" value="Surfaces&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;/v1/connector/analyze (NEW — ML Commons shape, returns output.message) · /v1/chat + /v1/chat/sync + /v1/tools (per-user, unchanged) · /mcp streamable HTTP (V3.3)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v1gw"><mxGeometry x="20" y="40" width="580" height="90" as="geometry"/></mxCell>
        <mxCell id="v1gr" value="Environment registry (D43)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;credential → env → {indexer url, CA, reader principal, budgets, locale, kill switch} · env identity NEVER from the payload (D6) · per-env admission, evidence cache, lane-0 vectors, audit stream&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v1gw"><mxGeometry x="20" y="150" width="580" height="100" as="geometry"/></mxCell>
        <mxCell id="v1gc" value="THE SAME CORE — unchanged guarantees&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;scope classifier · lane 0 + near-miss few-shot · typed tools (alerts, knowledge, environment) · lane 2 IR · compiler with allowlist, no scripts (D4) · four veracity checks (D24) · citation + grounded-number verification · verifiability label (D23) — the model still never writes a query and never computes a number&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v1gw"><mxGeometry x="20" y="270" width="580" height="130" as="geometry"/></mxCell>
        <mxCell id="v1gp" value="Provider port (unchanged)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;Ollama local-first (gpt-oss:20b, 16 GB budget, D46) · Bedrock for production · two tiers (D37/D39)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v1gw"><mxGeometry x="20" y="420" width="280" height="100" as="geometry"/></mxCell>
        <mxCell id="v1ga" value="Actions v3.5–v3.8 (D20/D35/D53/D54)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;propose_* tools → card → confirm · tiered executor creds (dashboard/manager/AR), never the model · per-env tier opt-in (deny default) · high-risk target echo + idempotency + rate caps · confirm via /v1/actions OR conversational &#39;yes&#39;/&#39;no&#39; (D54, deterministic, outside the model)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v1gw"><mxGeometry x="320" y="420" width="280" height="100" as="geometry"/></mxCell>
        <mxCell id="v1llm" value="Ollama / Bedrock&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;inference only — never sees a credential, never writes a query&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1380" y="380" width="220" height="90" as="geometry"/></mxCell>
        <mxCell id="v1direct" value="Direct edges keep FULL per-user identity (D11/D52)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;n8n · API · MCP-with-JWT: analyst creds → shim verifies via the env&#39;s indexer authinfo (no IdP — the environment&#39;s own user store) → turn JWT → queries as the analyst — nothing in v3 weakens this&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF6F7;strokeColor=#DD344C;dashed=1;fontColor=#DD344C;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="660" y="750" width="620" height="80" as="geometry"/></mxCell>
        <mxCell id="v1eg1" value="X-Env-Key (per-env credential)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;strokeWidth=2;" edge="1" parent="1" source="v1e1m" target="v1gs"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="v1eg2" value="reads as wazuh_ai_env_reader (read-only)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1B8354;fontColor=#1B8354;fontSize=10;" edge="1" parent="1" source="v1gc" target="v1e1i"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="620" y="335"/><mxPoint x="620" y="310"/></Array></mxGeometry></mxCell>
        <mxCell id="v1eg3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="v1gp" target="v1llm"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="v1eg4" value="env B…N connectors (own keys)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;dashed=1;" edge="1" parent="1" source="v1e2" target="v1gr"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v3b" name="2 · v3 PoC: single environment on the harness">
    <mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1660" pageHeight="1010" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="v2t" value="v3 PoC — environment `lab` on the existing docker harness" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="1500" height="32" as="geometry"/></mxCell>
        <mxCell id="v2s" value="Single environment, multi-environment interfaces: the registry has one entry, the code paths are the N-env paths · bring-up: make dashboard-assistant → make assistant-setup → make evals-connector · 16 GB inference budget: gpt-oss:20b, embeddings in-cluster" style="text;html=1;fontSize=12;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="52" width="1580" height="20" as="geometry"/></mxCell>
        <mxCell id="v2wz" value="wazuh-docker single-node — environment `lab`" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B8354;strokeWidth=2;fontColor=#1B8354;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="560" height="420" as="geometry"/></mxCell>
        <mxCell id="v2d" value="wazuh-dashboard :443 — DERIVED IMAGE&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;dashboard-assistant/Dockerfile bakes assistantDashboards + mlCommonsDashboards (version from package.json → artifacts.opensearch.org bundle) · assistant.chat.enabled: true in the mounted yml&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v2wz"><mxGeometry x="20" y="40" width="520" height="110" as="geometry"/></mxCell>
        <mxCell id="v2i" value="wazuh-indexer :9200 (OpenSearch 2.19.5)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;scripts/dashboard_assistant_setup.sh creates: cluster settings (trusted_connector_endpoints_regex += ^http://tool-service:8080/.*$) · remote model + connector (X-Env-Key, request_timeout 120s) · conversational agent (max_iteration 1, memory conversation_index) · root agent in .plugins-ml-config&lt;br&gt;principals: analyst JWT auth domain (existing) + wazuh_ai_env_reader (NEW, read-only) · embeddings model (C3)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="v2wz"><mxGeometry x="20" y="170" width="520" height="160" as="geometry"/></mxCell>
        <mxCell id="v2m" value="wazuh-manager&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;API :55000 untouched in v3 — actions deferred (D47)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6B86;dashed=1;fontColor=#5A6B86;fontSize=11;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v2wz"><mxGeometry x="20" y="350" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="v2gw" value="tool-service :8080 — the gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=2;fontColor=#232F3E;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=6;" vertex="1" parent="1"><mxGeometry x="680" y="100" width="500" height="420" as="geometry"/></mxCell>
        <mxCell id="v2g1" value="POST /v1/connector/analyze (NEW)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;auth X-Env-Key → environments.resolve_by_key → EnvPrincipal(lab) · body {parameters:{prompt}} · returns {output:{message: answer + label + &#39;environment-scoped identity&#39;}} · 110 s budget, budget-note over 504&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v2gw"><mxGeometry x="20" y="40" width="460" height="110" as="geometry"/></mxCell>
        <mxCell id="v2g2" value="environments.yaml — one entry: lab&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;gateway_key · indexer url/CA · reader principal · per-env admission/cache/vectors/audit keyed by env_id (V3.1a)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v2gw"><mxGeometry x="20" y="170" width="460" height="90" as="geometry"/></mxCell>
        <mxCell id="v2g3" value="run_turn(principal) — User (JWT) | EnvPrincipal&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;V3.8: pending proposal + yes/no → deterministic confirm (bypasses model, D54) · same lanes, tools, IR, checks for both principals · /v1/chat(/sync) per-user · connector yes executes under env principal (D53)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="v2gw"><mxGeometry x="20" y="280" width="460" height="120" as="geometry"/></mxCell>
        <mxCell id="v2ol" value="ollama :11434 (rocm)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;gpt-oss:20b only — embeddings moved in-cluster (C3) · ≈13 GB + KV in the 16 GB budget&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1260" y="140" width="340" height="100" as="geometry"/></mxCell>
        <mxCell id="v2ex" value="direct edges (V3.6: no Keycloak)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;auth-shim :8081 (verifies creds via indexer authinfo, D52) + n8n :5678 → per-user turn JWT (D11) · golden set via make evals (direct) and make evals-connector (dashboard path, agent _execute)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF6F7;strokeColor=#DD344C;dashed=1;fontColor=#DD344C;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1260" y="280" width="340" height="130" as="geometry"/></mxCell>
        <mxCell id="v2acc" value="acceptance (V3.1): Assistant icon answers in the dashboard · six storyline questions match n8n answers + env-scoped label · evals-connector green (identity cases explicitly SKIPPED, never silent) · env reader can read / cannot DELETE · wrong X-Env-Key → 401 + audit · make test and make evals stay green" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;align=left;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="40" y="560" width="1140" height="80" as="geometry"/></mxCell>
        <mxCell id="v2e1" value="X-Env-Key" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;strokeWidth=2;" edge="1" parent="1" source="v2i" target="v2g1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="v2e2" value="reads as env_reader" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1B8354;fontColor=#1B8354;fontSize=10;" edge="1" parent="1" source="v2g3" target="v2i"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="640" y="340"/><mxPoint x="640" y="280"/></Array></mxGeometry></mxCell>
        <mxCell id="v2e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="v2gw" target="v2ol"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="v2e4" value="chat in the dashboard" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="v2d" target="v2i"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
