<mxfile host="app.diagrams.net" type="device" version="24.7.17">
  <diagram id="wf" name="v3.8 turn workflow (as built)">
    <mxGraphModel dx="1400" dy="820" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1720" pageHeight="1120" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="wazuh-ai v3.8 - one turn end to end (as built)" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="1500" height="32" as="geometry"/></mxCell>
        <mxCell id="s" value="Two edges, one core. The model never writes a query and never computes a number (D4). Read lanes ranked by verifiability; writes are propose→confirm (D20). Identity: per-USER on direct edges (D11/D52), per-ENVIRONMENT on the dashboard edge (D42). Green = read path · orange = write/actions · red = identity." style="text;html=1;fontSize=12;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="52" width="1640" height="20" as="geometry"/></mxCell>

        <!-- entry edges -->
        <mxCell id="e_dash" value="Dashboard Assistant edge&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;OpenSearch Dashboards chat → ML Commons remote model → HTTP connector (X-Env-Key) → /v1/connector/analyze · env-scoped principal (D42) · answer labeled &#39;environment-scoped identity&#39;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF6F7;strokeColor=#DD344C;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="40" y="96" width="360" height="120" as="geometry"/></mxCell>
        <mxCell id="e_direct" value="Direct edges (per-user, D11/D52)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;n8n · API · MCP · confirm UI → analyst Basic creds → auth-shim verifies via env indexer authinfo (no IdP) → turn JWT ≤10 min → queries as the analyst&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF6F7;strokeColor=#DD344C;fontColor=#232F3E;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="420" y="96" width="360" height="120" as="geometry"/></mxCell>

        <!-- admission + env resolve -->
        <mxCell id="adm" value="Gateway: resolve principal + admission&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;env key → env registry (indexer, CA, reader, tiers, budgets - env id NEVER from payload, D6/D43) · one stream/user, per-tenant semaphore, honest 429 (D14) · per-env kill switch&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="180" y="256" width="440" height="90" as="geometry"/></mxCell>

        <!-- confirm short-circuit -->
        <mxCell id="conf" value="Pending action + &#39;yes/no&#39;? → deterministic confirm (D54)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;bilingual intent match OUTSIDE the model · direct: JWT tier role (operator/responder) · connector: executes under env principal (D53) · high-risk needs target echo · idempotency · rate cap · else → cascade&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="700" y="250" width="420" height="100" as="geometry"/></mxCell>

        <!-- language + scope -->
        <mxCell id="lang" value="Language + scope (V3.8a / P1.2)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;detect(question) → answer language (fixes cross-lingual leak) · embedding scope classifier refuses off-topic/injection before any model (fails open)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="180" y="386" width="440" height="80" as="geometry"/></mxCell>

        <!-- lane cascade -->
        <mxCell id="cascade" value="Read lane cascade (verifiability order)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B8354;strokeWidth=2;fontColor=#1B8354;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=6;" vertex="1" parent="1"><mxGeometry x="120" y="500" width="560" height="330" as="geometry"/></mxCell>
        <mxCell id="l0" value="Lane 0 (D40): one embedding → curated template → typed IR · no model · near-miss (0.65-0.80) becomes a few-shot hint. Siblings, also no model: reference router (rule/field/capability recognitions → exact tool, F6) and playbooks (D55, curated multi-step investigations, each step veracity-checked)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#232F3E;fontSize=11;align=left;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="cascade"><mxGeometry x="20" y="40" width="520" height="60" as="geometry"/></mxCell>
        <mxCell id="l1" value="Lane 1: model picks TYPED tools (schema-validated params). Reads: count_alerts, auth_failures, brute_force_summary, top_rules, search_alerts, alert_histogram, alert_timeline, related_alerts, compare_windows, mitre_coverage, agent_posture · knowledge: mitre_lookup, knowledge_search (Wazuh docs KB, D60), rule_reference / field_dictionary / describe_capabilities (D61) · env: list_agents, index_health, list_dashboards · states: count_vulnerabilities. Per-intent tool subsetting (D62) trims the offered set; fails open." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#232F3E;fontSize=11;align=left;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="cascade"><mxGeometry x="20" y="110" width="520" height="90" as="geometry"/></mxCell>
        <mxCell id="l2" value="Lane 2: model emits a typed Query IR → allowlist-checked → compiled to OpenSearch DSL server-side (no scripts/regexp/wildcards, D22)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#232F3E;fontSize=11;align=left;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="cascade"><mxGeometry x="20" y="210" width="520" height="60" as="geometry"/></mxCell>
        <mxCell id="ctx" value="Per-turn context (transient, cache-safe): env card (agents/OS/geo/dashboards, 15-min TTL) · domain/reporting/dashboards prompt modules · language line - never in the static cached prelude" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6B86;dashed=1;fontColor=#5A6B86;fontSize=10;align=left;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="cascade"><mxGeometry x="20" y="280" width="520" height="40" as="geometry"/></mxCell>

        <!-- actions propose -->
        <mxCell id="act" value="Write actions (lane A, D20/D35)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;model calls propose_* (create_dashboard, restart_agent, active_response) → typed schema + preview → proposal card, NOT executed · per-env tier opt-in (deny default) · tiered executor creds, never the model · confirm via /v1/actions OR conversational &#39;yes&#39; (see top)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="720" y="500" width="400" height="130" as="geometry"/></mxCell>

        <!-- veracity -->
        <mxCell id="ver" value="Veracity pipeline (D24) - every read lane funnels here&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;1 mapping validation · 2 dry-run · 3 execute AS THE PRINCIPAL (turn JWT or env reader) · 4 zero-hit diagnosis · evidence cache (IR-keyed, disclosed, D41) · executed_window on every result&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;fontColor=#232F3E;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="180" y="880" width="500" height="120" as="geometry"/></mxCell>

        <!-- indexer / manager -->
        <mxCell id="idx" value="Wazuh Indexer&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;wazuh-alerts-* · wazuh-states-vulnerabilities-* · saved objects (dashboards) · embeddings model (C3) · JWT auth domain + read-only roles · query, don&#39;t embed (D4/D5)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="740" y="700" width="360" height="110" as="geometry"/></mxCell>
        <mxCell id="mgr" value="Wazuh Manager API&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;agent restart · active-response (agents_list) · least-privilege executor users per tier&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1160" y="500" width="340" height="90" as="geometry"/></mxCell>

        <!-- synthesis / answer -->
        <mxCell id="ans" value="Answer assembly&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;citation check [alert]/[agg]/[kb] against what was retrieved · grounded-number check (cited counts = evidence values) · verifiability label (D23) · corrections surfaced, never hidden · streamed / connector one-shot&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="740" y="880" width="500" height="120" as="geometry"/></mxCell>
        <mxCell id="prov" value="Inference port (llm.py): Ollama gpt-oss:20b (local, 16 GB) · Bedrock · OpenAI-compatible - never sees a credential, never writes a query" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6B86;dashed=1;fontColor=#5A6B86;fontSize=10;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1300" y="880" width="380" height="120" as="geometry"/></mxCell>

        <!-- edges -->
        <mxCell id="ed1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#DD344C;fontColor=#DD344C;fontSize=10;" edge="1" parent="1" source="e_dash" target="adm"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#DD344C;fontColor=#DD344C;fontSize=10;" edge="1" parent="1" source="e_direct" target="adm"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed3" value="pending + yes/no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="adm" target="conf"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed4" value="otherwise" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="adm" target="lang"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed5" value="in scope" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1B8354;fontColor=#1B8354;fontSize=10;" edge="1" parent="1" source="lang" target="cascade"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed6" value="model picks propose_*" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="l1" target="act"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed7" value="every read tool" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1B8354;fontColor=#1B8354;fontSize=10;" edge="1" parent="1" source="cascade" target="ver"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed8" value="as the principal" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1B8354;fontColor=#1B8354;fontSize=10;" edge="1" parent="1" source="ver" target="idx"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed9" value="confirmed write" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="act" target="mgr"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed9b" value="dashboards → saved objects" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="act" target="idx"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed10" value="evidence" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1B8354;fontColor=#1B8354;fontSize=10;" edge="1" parent="1" source="ver" target="ans"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed11" value="confirm result" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="conf" target="ans"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1300" y="300"/><mxPoint x="1300" y="820"/></Array></mxGeometry></mxCell>
        <mxCell id="ed12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="ans" target="prov"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
