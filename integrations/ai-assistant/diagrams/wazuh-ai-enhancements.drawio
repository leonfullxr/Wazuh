  <diagram id="enh3" name="3 · Local test harness (AMD)">
    <mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1660" pageHeight="1010" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="e3t" value="Local test harness on the AMD box, and the eval workflow" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="1400" height="32" as="geometry"/></mxCell>
        <mxCell id="e3s" value="AS BUILT · measured 2026-07-14 — lane 0 on, gpt-oss:20b: 9/9 (7/9 zero-token) · model-only: qwen3:30b-a3b-instruct-2507 9/9 med 16.8 s zero corrections · gpt-oss:20b 7–8/9 med 15.2 s · qwen2.5:14b 2/9 · qwen3 thinking tag 3/9 (output-cap overflow)" style="text;html=1;fontSize=12;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="52" width="1560" height="20" as="geometry"/></mxCell>
        <mxCell id="e3host" value="This machine — Linux · 64 GB RAM (unrelated stacks share it: stop them before runs) · AMD RX 7600 XT 16 GB VRAM (gfx1102)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=2;fontColor=#232F3E;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=6;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="1580" height="520" as="geometry"/></mxCell>
        <mxCell id="e3wz" value="wazuh-docker single-node&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;manager · indexer :9200 · dashboard :443&lt;br&gt;≈10 GB RAM · network single-node_default&lt;br&gt;JWT auth domain + wazuh_ai_analyst_role applied via make securityconfig&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="e3host"><mxGeometry x="40" y="60" width="440" height="160" as="geometry"/></mxCell>
        <mxCell id="e3ov" value="PoC overlay (make poc)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;keycloak :8085 · auth-shim :8081 (SHIM_KC_ISSUER pinned) · tool-service :8080 · n8n :5678&lt;br&gt;lane 0 ON · evidence cache 60 s · WAI_EVIDENCE_BUDGET_CHARS=8000&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="e3host"><mxGeometry x="520" y="60" width="460" height="160" as="geometry"/></mxCell>
        <mxCell id="e3ol" value="ollama :11434 — ollama/ollama:rocm (P0.1)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;devices /dev/kfd + /dev/dri · numeric GIDs (render 105 / video 44)&lt;br&gt;OLLAMA_CONTEXT_LENGTH=16384 (P0.2) · FLASH_ATTENTION=1 · KV q8_0&lt;br&gt;NUM_PARALLEL=1 (prefix KV reuse) · KEEP_ALIVE=30m&lt;br&gt;measured: gpt-oss:20b 90% GPU · qwen3:30b-a3b 65% GPU / 35% CPU&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="e3host"><mxGeometry x="1020" y="60" width="520" height="160" as="geometry"/></mxCell>
        <mxCell id="e3gpu" value="verified: ollama ps → 90% GPU on gpt-oss:20b with 16k context · warm turn ≈ 14 s including load" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;align=left;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="e3host"><mxGeometry x="1020" y="250" width="520" height="60" as="geometry"/></mxCell>
        <mxCell id="e3air" value="airllm-shim: CUDA-only, unsupported on this host — skipped by design" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6B86;dashed=1;fontColor=#5A6B86;fontSize=11;align=left;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="e3host"><mxGeometry x="1020" y="340" width="520" height="50" as="geometry"/></mxCell>
        <mxCell id="e3neg" value="identity negatives — all verified green: foreign-key token rejected at signature · cross-tenant token rejected + audited · viewer1 refused by the shim (403) · turn JWT can _count but DELETE → 403" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF6F7;strokeColor=#DD344C;dashed=1;fontColor=#DD344C;fontSize=11;align=left;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="e3host"><mxGeometry x="40" y="250" width="940" height="70" as="geometry"/></mxCell>
        <mxCell id="e3models" value="bake-off (lane 0 off, one artifact per model — golden/last_run.&amp;lt;model&amp;gt;.json): qwen3:30b-a3b-instruct-2507-q4_K_M 9/9 · gpt-oss:20b 7–8/9 · qwen2.5:14b 2/9 · qwen3 thinking 3/9. Compared on: pass rate · per-case seconds · tokens/turn · corrections" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;align=left;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="e3host"><mxGeometry x="40" y="350" width="940" height="80" as="geometry"/></mxCell>
        <mxCell id="e3cache" value="cache checks verified: second identical query inside the TTL disclosed served_from_cache (rendered into the lane-0 label) · Bedrock cacheRead/Write token surfacing built, awaiting an AWS-credentialed run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;align=left;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="e3host"><mxGeometry x="40" y="440" width="1500" height="60" as="geometry"/></mxCell>
        <mxCell id="e3s1" value="make seed — idempotent (P0.3)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;delete prior synthetic docs (marker on manager.name) → reseed 2000 → fresh ground_truth.json&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="40" y="680" width="240" height="110" as="geometry"/></mxCell>
        <mxCell id="e3s2" value="identity chain&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;Keycloak password grant → shim exchange → turn JWT, fresh per case (≤10 min TTL vs slow local turns)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="320" y="680" width="240" height="110" as="geometry"/></mxCell>
        <mxCell id="e3s3" value="live references (P0.4)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;counts via /v1/tools (same code path as the assistant), both window readings bracketed · top rule + sample id via live_gt.py (WAI_EVAL_INDEXER_URL)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="600" y="680" width="260" height="110" as="geometry"/></mxCell>
        <mxCell id="e3s4" value="9 bilingual cases&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;POST /v1/chat/sync · WAI_EVAL_TIMEOUT_S · 429s waited out, never failed&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="900" y="680" width="220" height="110" as="geometry"/></mxCell>
