<mxfile host="app.diagrams.net" type="device" version="24.7.17">
  <diagram id="enh1" name="1 · Enhanced turn workflow">
    <mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1660" pageHeight="1010" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="e1t" value="One question through the enhanced cascade (HISTORICAL — identity now via indexer authinfo V3.6, no Keycloak)" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="1400" height="32" as="geometry"/></mxCell>
        <mxCell id="e1s" value="AS BUILT · orange = the July 2026 enhancement pass, shipped and validated (golden set 9/9 with lane 0 on; 7 of 9 cases answer with zero model tokens)" style="text;html=1;fontSize=12;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="52" width="1400" height="20" as="geometry"/></mxCell>
        <mxCell id="e1id" value="Identity (unchanged)&lt;br&gt;&lt;font style=&quot;font-size:11px&quot; color=&quot;#5A6B86&quot;&gt;Keycloak OIDC → auth-shim mints turn JWT ≤10 min (mint key only there, D30) → core and indexer verify with the public key · tenant claim from deployment config (D6) · queries execute as the analyst (D11) · shim pins the host-facing issuer via SHIM_KC_ISSUER&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF6F7;strokeColor=#DD344C;dashed=1;fontColor=#DD344C;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="40" y="90" width="470" height="120" as="geometry"/></mxCell>
        <mxCell id="e1q" value="Analyst question + turn JWT&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;n8n edge (D28) · admission first: one stream per user, honest 429 (D14)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="40" y="300" width="210" height="90" as="geometry"/></mxCell>
        <mxCell id="e1cls" value="Scope and tier classifier (P1.4)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;one bge-m3 embedding per question, shared by lane 0, scope and few-shot · refuses only when clearly out of scope (fails open) · greetings bypass it · regex fallback when embeddings are off&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="310" y="285" width="240" height="120" as="geometry"/></mxCell>
        <mxCell id="e1b1" value="smalltalk / out-of-scope&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;canned bilingual refusal, NO model, NO tools — the injection and out-of-scope golden cases pass structurally&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="640" y="110" width="260" height="90" as="geometry"/></mxCell>
        <mxCell id="e1b2" value="Lane 0 template match (D40)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;cosine ≥ 0.80 + required slots filled → typed IR · no model involved · label discloses served-from-cache&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="640" y="240" width="260" height="90" as="geometry"/></mxCell>
        <mxCell id="e1b3" value="Near-miss band 0.65–0.80 (P1.3)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;closest exemplar injected as a transient few-shot message (after the static prefix, never stored) → analysis loop&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="640" y="370" width="260" height="100" as="geometry"/></mxCell>
        <mxCell id="e1lp" value="Analysis loop — ≤ 6 tool calls, streamed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=2;fontColor=#232F3E;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=6;" vertex="1" parent="1"><mxGeometry x="970" y="110" width="350" height="390" as="geometry"/></mxCell>
        <mxCell id="e1lp1" value="Model step — prompt caching&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;Bedrock: cachePoint on tools+system AND on the last user message per step (P1.1) · local: byte-stable prefix → KV reuse, NUM_PARALLEL=1 (P1.2) · UTC clock floored to the minute, stamped once per turn&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e1lp"><mxGeometry x="20" y="40" width="310" height="110" as="geometry"/></mxCell>
        <mxCell id="e1lp2" value="Typed tool calls, lanes 1–2 (D4/D22)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;schema-validated params → Query IR · rejected calls return as tool errors the model corrects from&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e1lp"><mxGeometry x="20" y="170" width="310" height="90" as="geometry"/></mxCell>
        <mxCell id="e1lp3" value="mitre_lookup knowledge tool (P1.6)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;curated ATT&amp;amp;CK JSON shipped in the image (02 §10) · exact T-number lookup, no embeddings · cited as [kb:Txxxx]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e1lp"><mxGeometry x="20" y="280" width="310" height="90" as="geometry"/></mxCell>
        <mxCell id="e1vp" value="Veracity pipeline (D24) — every lane funnels through here&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;1 mapping validation · 2 dry-run · 3 execute as the analyst (turn JWT) · 4 zero-hit differential diagnosis&lt;br&gt;+ evidence cache: IR-keyed, TTL grid, always disclosed served_from_cache (D41) · executed_window returned on every result&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=12;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="640" y="560" width="560" height="130" as="geometry"/></mxCell>
        <mxCell id="e1idx" value="Wazuh Indexer&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;JWT auth domain · read-only analyst role · the retrieval layer: query, don&#39;t embed (D4/D5)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1290" y="570" width="220" height="110" as="geometry"/></mxCell>
        <mxCell id="e1lr" value="Lane 0 local render (D26)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;code writes the answer from datastore-computed results · label: no model involved&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="300" y="580" width="240" height="90" as="geometry"/></mxCell>
        <mxCell id="e1out" value="Answer assembly&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;citation check [alert:]/[agg:]/[kb:] against what was actually retrieved · grounded-number check: cited counts must equal evidence values (P1.5 — caught a live hallucination in the bake-off) · verifiability label (D23) · corrections surfaced, never hidden&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1290" y="760" width="270" height="140" as="geometry"/></mxCell>
        <mxCell id="e1ans" value="Analyst sees answer + label + usage&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;SSE tokens · audit event per turn · Prometheus per lane · cacheRead/Write tokens surfaced&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="920" y="785" width="260" height="90" as="geometry"/></mxCell>
        <mxCell id="e1e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="e1q" target="e1cls"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1e2" value="scope ≠ telemetry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="e1cls" target="e1b1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1e3" value="recognition ≥ 0.80" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="e1cls" target="e1b2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1e4" value="almost recognized" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="e1cls" target="e1b3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1e5" value="else: analysis tier" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;exitX=1;exitY=0.75;exitDx=0;exitDy=0;" edge="1" parent="1" source="e1cls" target="e1lp"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="600" y="490"/><mxPoint x="940" y="490"/></Array></mxGeometry></mxCell>
        <mxCell id="e1e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="e1b3" target="e1lp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1e7" value="typed IR" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="e1b2" target="e1vp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1e8" value="every tool call" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="e1lp" target="e1vp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1e9" value="compiled DSL, as the analyst" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1B8354;fontColor=#1B8354;fontSize=10;" edge="1" parent="1" source="e1vp" target="e1idx"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1e10" value="lane 0 evidence" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="e1vp" target="e1lr"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1e11" value="final text" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="e1lp" target="e1out"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1420" y="300"/></Array></mxGeometry></mxCell>
        <mxCell id="e1e12" value="polite reply, no tools" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="e1b1" target="e1out"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1600" y="155"/><mxPoint x="1600" y="760"/></Array></mxGeometry></mxCell>
        <mxCell id="e1e13" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="e1lr" target="e1ans"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="420" y="830"/></Array></mxGeometry></mxCell>
        <mxCell id="e1e14" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="e1out" target="e1ans"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="enh2" name="2 · Caches and knowledge placement">
    <mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1660" pageHeight="1010" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="e2t" value="Where each cache and knowledge source lives" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="1400" height="32" as="geometry"/></mxCell>
        <mxCell id="e2s" value="AS BUILT · orange = the July 2026 enhancement pass · telemetry is never embedded — the only vector math in the system is over questions and curated exemplars (D4/D5, note 02) · one embedding per question drives lane 0, scope and few-shot" style="text;html=1;fontSize=12;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="52" width="1500" height="20" as="geometry"/></mxCell>
        <mxCell id="e2kc" value="Keycloak&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;customer IdP stand-in · OIDC&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF6F7;strokeColor=#DD344C;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="40" y="140" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="e2as" value="auth-shim&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;verifies OIDC vs JWKS · SHIM_KC_ISSUER pins the host-facing issuer · mints turn JWT ≤10 min · mint key ONLY here (D30)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF6F7;strokeColor=#DD344C;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="40" y="260" width="200" height="100" as="geometry"/></mxCell>
        <mxCell id="e2n8" value="n8n chat edge&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;thin relay only (D28) · renders the verifiability label&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="40" y="400" width="200" height="90" as="geometry"/></mxCell>
        <mxCell id="e2mcp" value="MCP adapter (mcp/server.py)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;stdio door for Claude Desktop / Cursor · mints and refreshes its own turn JWT · consumes the HTTP surfaces, never the datastore&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="40" y="520" width="200" height="110" as="geometry"/></mxCell>
        <mxCell id="e2ts" value="tool-service — FastAPI, deliberately single-process (semaphores, caches and vectors are process-local)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=2;fontColor=#232F3E;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacing=8;arcSize=6;" vertex="1" parent="1"><mxGeometry x="310" y="120" width="660" height="660" as="geometry"/></mxCell>
        <mxCell id="e2m1" value="loop.py — the agent loop&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;lane cascade · citation check ([kb:] included) · grounded-number check (P1.5) · few-shot injection (P1.3) · per-turn minute-floored clock&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e2ts"><mxGeometry x="20" y="40" width="300" height="100" as="geometry"/></mxCell>
        <mxCell id="e2m2" value="lane0.py + embeddings.py + scope.py&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;bilingual exemplar corpus + vectors · one shared per-turn embed cache · scope corpora (fails open) · near-miss few-shot · deterministic slots&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e2ts"><mxGeometry x="340" y="40" width="300" height="100" as="geometry"/></mxCell>
        <mxCell id="e2m3" value="tools.py + knowledge.py&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;typed lane-1 catalog · run_query_ir (lane 2) · mitre_lookup over curated ATT&amp;amp;CK JSON baked into the image — exact-id lookup, no vector store (P1.6)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e2ts"><mxGeometry x="20" y="160" width="300" height="110" as="geometry"/></mxCell>
        <mxCell id="e2m4" value="models.py + compiler.py&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;typed Query IR · field allowlist · compiles to OpenSearch DSL, values only in filter clauses, no scripts/regexp/wildcards (D4/D22) — verified, unchanged&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e2ts"><mxGeometry x="340" y="160" width="300" height="110" as="geometry"/></mxCell>
        <mxCell id="e2m5" value="veracity.py&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;4 checks on every query (D24) · executed_window on every result · evidence cache: IR-keyed, TTL-grid, disclosed (D41)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e2ts"><mxGeometry x="20" y="290" width="300" height="110" as="geometry"/></mxCell>
        <mxCell id="e2m6" value="state.py — conversations&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;in-memory, TTL, text-only turns · documented seam → tenant indexer wazuh_ai_state (D7)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e2ts"><mxGeometry x="340" y="290" width="300" height="110" as="geometry"/></mxCell>
        <mxCell id="e2m7" value="admission.py (D14)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;1 stream/user · 6 turns/min · tenant semaphore · honest 429&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e2ts"><mxGeometry x="20" y="420" width="300" height="80" as="geometry"/></mxCell>
        <mxCell id="e2m8" value="audit.py + metrics.py&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;JSON events · Prometheus: turns by lane (incl. scope), tool calls, lane-0 outcomes, tokens, latency&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e2ts"><mxGeometry x="340" y="420" width="300" height="80" as="geometry"/></mxCell>
        <mxCell id="e2m9" value="main.py — the HTTP surfaces (D21)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;POST /v1/chat (SSE) · POST /v1/chat/sync · POST /v1/tools/{name} (no model) · the MCP adapter consumes these from the host&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="e2ts"><mxGeometry x="20" y="540" width="620" height="100" as="geometry"/></mxCell>
        <mxCell id="e2idx" value="Wazuh Indexer (OpenSearch)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;JWT auth domain · read-only wazuh_ai_analyst_role · THE retrieval layer: query, don&#39;t embed — no second copy of tenant data (D4/D5/D11)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1040" y="140" width="260" height="130" as="geometry"/></mxCell>
        <mxCell id="e2inf" value="provider port — llm.py&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;Converse shape everywhere · per-tier bindings (D37/D39) · streaming with usage frames&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1040" y="320" width="260" height="90" as="geometry"/></mxCell>
        <mxCell id="e2ol" value="Ollama (local, air-gapped)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;rocm image + /dev/kfd, /dev/dri, numeric GIDs (P0.1) · OLLAMA_CONTEXT_LENGTH=16384 (P0.2) · KV cache q8_0, prefix reuse = local prompt cache (P1.2) · gpt-oss:20b / qwen3-instruct + bge-m3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1040" y="440" width="260" height="150" as="geometry"/></mxCell>
        <mxCell id="e2br" value="Amazon Bedrock (production fidelity)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#5A6B86&quot;&gt;Converse + Guardrails per invocation (D38) · prompt cache: 2× cachePoint (P1.1) · cacheRead/Write tokens surfaced in usage · not yet exercised locally&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;strokeWidth=2;fontColor=#232F3E;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;spacing=6;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1040" y="620" width="260" height="140" as="geometry"/></mxCell>
        <mxCell id="e2anti" value="Anti-scope (still binding): vector store over alerts · semantic answer cache · lane 3 · LiteLLM in the default path (silent downgrade vs D14) · AirLLM on AMD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;dashed=1;fontColor=#DD344C;fontSize=11;align=left;verticalAlign=middle;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="310" y="810" width="990" height="60" as="geometry"/></mxCell>
