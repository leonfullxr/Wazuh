        <mxCell id="mgr" value="wazuh.manager :55000&#10;restart · active-response" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E8710A;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="wz"><mxGeometry x="60" y="250" width="78" height="78" as="geometry"/></mxCell>
        <mxCell id="agent" value="test agent&#10;(enrolled)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_container_registry;" vertex="1" parent="wz"><mxGeometry x="260" y="252" width="70" height="70" as="geometry"/></mxCell>

        <!-- ai-assistant containers group -->
        <mxCell id="ai" value="wazuh-ai containers (this project)" style="points=[];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=1;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud_alt;strokeColor=#232F3E;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" vertex="1" parent="host"><mxGeometry x="640" y="60" width="490" height="380" as="geometry"/></mxCell>
        <mxCell id="shim" value="auth-shim :8081&#10;mint key only here" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.key_management_service;" vertex="1" parent="ai"><mxGeometry x="40" y="60" width="70" height="70" as="geometry"/></mxCell>
        <mxCell id="gw" value="tool-service :8080&#10;lanes · veracity · actions · audit" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="ai"><mxGeometry x="210" y="55" width="78" height="78" as="geometry"/></mxCell>
        <mxCell id="ver" value="veracity gate&#10;4 checks · citations" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#1B8354;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.waf;" vertex="1" parent="ai"><mxGeometry x="390" y="55" width="70" height="70" as="geometry"/></mxCell>
        <mxCell id="n8n" value="n8n :5678&#10;(optional edge)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_load_balancing;" vertex="1" parent="ai"><mxGeometry x="40" y="250" width="70" height="70" as="geometry"/></mxCell>
        <mxCell id="ollama" value="ollama :11434 (ROCm)&#10;gpt-oss:20b - LOCAL LLM" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#01A88D;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.bedrock;" vertex="1" parent="ai"><mxGeometry x="240" y="248" width="78" height="78" as="geometry"/></mxCell>
        <mxCell id="gpu" value="AMD GPU&#10;(16 GB VRAM)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="ai"><mxGeometry x="400" y="250" width="70" height="70" as="geometry"/></mxCell>

        <!-- air-gapped banner -->
        <mxCell id="air" value="Air-gapped capable: with local Ollama, neither questions nor evidence ever leave this machine. Swap the inference port to Bedrock only if you accept egress." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#1B8354;fontSize=11;align=left;verticalAlign=middle;spacing=10;arcSize=8;" vertex="1" parent="host"><mxGeometry x="40" y="470" width="1090" height="50" as="geometry"/></mxCell>

        <!-- verification/eval -->
        <mxCell id="evals" value="Proven on this box: identity chain + negatives · golden set 15/15 (direct + connector) · actions 11/12 · dashboard create / agent restart / active-response end to end" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6B86;dashed=1;fontColor=#5A6B86;fontSize=11;align=left;verticalAlign=middle;spacing=10;arcSize=8;" vertex="1" parent="host"><mxGeometry x="40" y="560" width="1090" height="50" as="geometry"/></mxCell>

        <!-- bring-up -->
        <mxCell id="bring" value="Bring-up: make wazuh · securityconfig · dashboard-assistant · ollama · embed-mlcommons · poc · assistant-setup · seed · manager-executors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6B86;dashed=1;fontColor=#5A6B86;fontSize=11;align=left;verticalAlign=middle;spacing=10;arcSize=8;fontFamily=Courier New;" vertex="1" parent="host"><mxGeometry x="40" y="640" width="1090" height="50" as="geometry"/></mxCell>

        <!-- flows -->
        <mxCell id="f1" value="https :443 (chat in the dashboard)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="analyst" target="dash"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f2" value="ML Commons connector → /v1/connector/analyze" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="idx" target="gw"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f3" value="queries as the principal (turn JWT / env reader)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1B8354;fontColor=#1B8354;fontSize=10;" edge="1" parent="1" source="gw" target="idx"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f4" value="local inference" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="gw" target="ollama"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f5" value="confirmed writes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E8710A;fontColor=#E8710A;fontSize=10;" edge="1" parent="1" source="gw" target="mgr"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f6" value="offload" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6B86;fontColor=#5A6B86;fontSize=10;" edge="1" parent="1" source="ollama" target="gpu"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="posture" name="self-hosted vs cloud (icons)">
    <mxGraphModel dx="1400" dy="820" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="pt" value="Two deployment postures, one codebase" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="1000" height="32" as="geometry"/></mxCell>
        <mxCell id="ps" value="The gateway, core, identity, and veracity are identical; only where the pieces run and whether inference leaves the box differ." style="text;html=1;fontSize=12;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="50" width="1300" height="20" as="geometry"/></mxCell>

        <mxCell id="shb" value="Self-hosted (this PoC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F3EC;strokeColor=#1B8354;fontColor=#1B8354;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacing=10;arcSize=6;" vertex="1" parent="1"><mxGeometry x="60" y="100" width="640" height="440" as="geometry"/></mxCell>
        <mxCell id="sh1" value="· One machine, one Wazuh, one environment" style="text;html=1;fontSize=12;fontColor=#232F3E;align=left;" vertex="1" parent="shb"><mxGeometry x="20" y="50" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="sh2" value="· Gateway co-located with the indexer it queries" style="text;html=1;fontSize=12;fontColor=#232F3E;align=left;" vertex="1" parent="shb"><mxGeometry x="20" y="90" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="sh3" value="· Local LLM (Ollama) - air-gapped capable, no egress" style="text;html=1;fontSize=12;fontColor=#232F3E;align=left;" vertex="1" parent="shb"><mxGeometry x="20" y="130" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="sh4" value="· In-cluster ML Commons embeddings" style="text;html=1;fontSize=12;fontColor=#232F3E;align=left;" vertex="1" parent="shb"><mxGeometry x="20" y="170" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="sh5" value="· Both edges: dashboard chat + direct API/n8n/MCP" style="text;html=1;fontSize=12;fontColor=#232F3E;align=left;" vertex="1" parent="shb"><mxGeometry x="20" y="210" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="shi" value="single host" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#1B8354;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ec2;" vertex="1" parent="shb"><mxGeometry x="270" y="280" width="90" height="90" as="geometry"/></mxCell>

        <mxCell id="clb" value="Multi-environment / cloud (where it scales)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#E8710A;fontColor=#E8710A;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacing=10;arcSize=6;" vertex="1" parent="1"><mxGeometry x="740" y="100" width="640" height="440" as="geometry"/></mxCell>
        <mxCell id="cl1" value="· One central gateway serves N customer environments" style="text;html=1;fontSize=12;fontColor=#232F3E;align=left;" vertex="1" parent="clb"><mxGeometry x="20" y="50" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="cl2" value="· Per-env credential → env registry (indexer, CA, tiers)" style="text;html=1;fontSize=12;fontColor=#232F3E;align=left;" vertex="1" parent="clb"><mxGeometry x="20" y="90" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="cl3" value="· Bedrock (or a shared local fleet) behind the same port" style="text;html=1;fontSize=12;fontColor=#232F3E;align=left;" vertex="1" parent="clb"><mxGeometry x="20" y="130" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="cl4" value="· Per-env isolation: admission, cache, audit, kill switch" style="text;html=1;fontSize=12;fontColor=#232F3E;align=left;" vertex="1" parent="clb"><mxGeometry x="20" y="170" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="cl5" value="· Same code paths - the PoC registry just holds one entry" style="text;html=1;fontSize=12;fontColor=#232F3E;align=left;" vertex="1" parent="clb"><mxGeometry x="20" y="210" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="cli" value="N environments" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E8710A;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.route_53;" vertex="1" parent="clb"><mxGeometry x="270" y="280" width="90" height="90" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
