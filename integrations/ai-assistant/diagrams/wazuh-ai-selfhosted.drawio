<mxfile host="app.diagrams.net" type="device" version="24.7.17">
  <diagram id="selfhosted" name="self-hosted PoC (icons)">
    <mxGraphModel dx="1400" dy="820" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="wazuh-ai - self-hosted PoC (everything on one machine)" style="text;html=1;fontSize=22;fontStyle=1;fontColor=#232F3E;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="1300" height="32" as="geometry"/></mxCell>
        <mxCell id="s" value="One environment, one host, one Docker network. Local inference - nothing leaves the box (air-gapped capable). Same core, identity, and veracity as the multi-environment shape; the gateway just points at the co-located indexer." style="text;html=1;fontSize=12;fontColor=#5A6B86;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="50" width="1450" height="20" as="geometry"/></mxCell>

        <!-- analyst outside the box -->
        <mxCell id="analyst" value="Analyst&#10;(browser)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.users;" vertex="1" parent="1"><mxGeometry x="60" y="470" width="70" height="70" as="geometry"/></mxCell>

        <!-- the host boundary -->
        <mxCell id="host" value="Your machine - Docker Compose (single-node_default network)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;strokeWidth=3;fontColor=#232F3E;fontSize=14;fontStyle=1;align=left;verticalAlign=top;spacing=10;arcSize=4;dashed=0;" vertex="1" parent="1"><mxGeometry x="200" y="100" width="1180" height="820" as="geometry"/></mxCell>

        <!-- wazuh-docker single node group -->
        <mxCell id="wz" value="wazuh-docker single-node (4.14.5 / OpenSearch 2.19)" style="points=[];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=1;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud_alt;strokeColor=#1B8354;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#1B8354;dashed=0;" vertex="1" parent="host"><mxGeometry x="40" y="60" width="560" height="380" as="geometry"/></mxCell>
        <mxCell id="dash" value="wazuh.dashboard :443&#10;+ Assistant plugins" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E8710A;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;" vertex="1" parent="wz"><mxGeometry x="40" y="60" width="78" height="78" as="geometry"/></mxCell>
        <mxCell id="idx" value="wazuh.indexer :9200&#10;alerts · vuln states · saved objects&#10;+ ML Commons (connector + embeddings)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#01A88D;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elasticsearch_service;" vertex="1" parent="wz"><mxGeometry x="240" y="60" width="78" height="78" as="geometry"/></mxCell>
