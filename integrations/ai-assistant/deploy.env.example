# deploy.env.example — operator inputs for the E16 self-hosted installers.
#
# Copy to deploy.env and fill real values. Never commit deploy.env (secrets).
# These scripts target a PRE-EXISTING Wazuh — they never run `make wazuh`.

# ---- Paths ------------------------------------------------------------------
# Optional override: DEPLOY_ENV=/path/to/deploy.env

# ---- Indexer (required) -----------------------------------------------------
INDEXER_URL=https://wazuh.indexer:9200
INDEXER_ADMIN_USER=admin
INDEXER_ADMIN_PASSWORD=CHANGE_ME
# Pin the env CA (preferred). Leave empty only with INDEXER_VERIFY_TLS=false (lab).
INDEXER_CA_PATH=
INDEXER_VERIFY_TLS=true

# How the indexer reaches the gateway (ML Commons connector callback).
WAI_CONNECTOR_HOST=tool-service
WAI_CONNECTOR_PORT=8080

# Environment id + strong random gateway key (X-Env-Key / environments.yaml).
WAI_ENV_ID=lab
WAI_ENV_LAB_KEY=

# ---- Dashboard installer (install_dashboard_assistant.sh) -------------------
# package  = extract plugins onto this host's wazuh-dashboard install
# container = print / use dashboard-assistant/Dockerfile path (no host extract)
# skip     = plugins already installed; only wire ML Commons + embeddings
DASHBOARD_MODE=package

WAZUH_DASHBOARD_HOME=/usr/share/wazuh-dashboard
WAZUH_DASHBOARD_PLUGINS_DIR=/usr/share/wazuh-dashboard/plugins
WAZUH_DASHBOARD_CONFIG=/etc/wazuh-dashboard/opensearch_dashboards.yml
WAZUH_DASHBOARD_SERVICE=wazuh-dashboard
# Set true to skip restart (operator restarts manually).
SKIP_DASHBOARD_RESTART=false

# Embeddings: call mlcommons_embed_setup.sh unless SKIP_EMBEDDINGS=true
# or you already set WAI_EMBED_* to an external endpoint.
SKIP_EMBEDDINGS=false
# WAI_EMBED_PROVIDER=openai
# WAI_EMBED_BASE_URL=http://ollama:11434/v1
# WAI_EMBED_MODEL=bge-m3

# ---- Gateway installer (install_gateway.sh) ---------------------------------
# compose  = docker compose up tool-service + auth-shim (+ optional ollama)
# systemd  = install systemd units that wrap the compose project
DEPLOY_MODE=compose

# Docker network the gateway joins so the indexer can reach tool-service.
# For wazuh-docker single-node this is typically single-node_default.
COMPOSE_NETWORK=single-node_default
COMPOSE_FILE=docker-compose.poc.yml

# Local LLM (ignored when WAI_LLM_PROVIDER=bedrock and AWS creds are set).
WAI_LLM_PROVIDER=openai
WAI_LLM_BASE_URL=http://ollama:11434/v1
WAI_MODEL_ROUTER=gpt-oss:20b
WAI_MODEL_ANALYSIS=gpt-oss:20b
OLLAMA_MODEL=gpt-oss:20b
PULL_OLLAMA_MODEL=true
START_OLLAMA=true

# Securityconfig apply:
#   docker = use securityconfig/apply.sh (INDEXER_CONTAINER must exist)
#   merge-only = merge fragments into INDEXER_SC_WORKDIR; operator runs securityadmin
SECURITYCONFIG_MODE=docker
INDEXER_CONTAINER=single-node-wazuh.indexer-1
# INDEXER_SC_WORKDIR=/tmp/wazuh-ai-securityconfig

# Env registry output (generated from environments.yaml.example + these values).
ENVIRONMENTS_OUT=environments.yaml
WAI_ENV_LAB_READER=wazuh_ai_env_reader:EnvReaderLab1!
WAI_ENV_LAB_DASHBOARD_API_URL=https://localhost:5601
WAI_ENV_LAB_DASHBOARD_EXECUTOR=
WAI_ENV_LAB_MONITOR_EXECUTOR=
MANAGER_API_URL=https://wazuh.manager:55000
# Comma list of action tiers to enable (deny-by-default). Example: dashboard,manager
ACTIONS_TIERS=dashboard

# Executor RBAC (only when manager or active_response is in ACTIONS_TIERS).
SETUP_MANAGER_EXECUTORS=auto
WAZUH_API_URL=https://localhost:55000
WAZUH_ADMIN=wazuh-wui:CHANGE_ME
WAI_MANAGER_OP_PASSWORD=
WAI_AR_EXEC_PASSWORD=

# Systemd install prefix when DEPLOY_MODE=systemd
SYSTEMD_INSTALL_DIR=/opt/wazuh-ai
SYSTEMD_UNIT_DIR=/etc/systemd/system
