# ---- Wazuh stack ------------------------------------------------------------
# wazuh-docker tag to clone (verify the tag exists: https://github.com/wazuh/wazuh-docker/tags)
WAZUH_VERSION=4.14.5
# Default admin credentials of the wazuh-docker single-node stack (change in anything non-lab)
INDEXER_ADMIN_USER=admin
INDEXER_ADMIN_PASSWORD=SecretPassword

# ---- Tenant / identity -------------------------------------------------------
WAI_TENANT=lab
WAI_JWT_ISSUER=wazuh-ai-shim.lab
WAI_JWT_AUDIENCE=wazuh-ai-backend.lab
WAI_JWT_INDEXER_AUDIENCE=wazuh-indexer.lab
WAI_JWT_TTL_SECONDS=600

# Keycloak (the customer IdP stand-in)
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
KC_REALM=wazuh-poc
KC_CLIENT_ID=wazuh-ai
# In-network URL used by the shim to fetch JWKS
KC_URL=http://keycloak:8080
# Issuer stamped on host-minted OIDC tokens (Keycloak derives iss from the request URL)
KC_ISSUER=http://localhost:8085/realms/wazuh-poc

# Host-side eval runner indexer URL (do not use WAI_INDEXER_URL — that is in-network)
WAI_EVAL_INDEXER_URL=https://localhost:9200

# ---- Inference backend (pick ONE option, see README s3) ----------------------
# WAI_LLM_PROVIDER selects the adapter in tool-service/app/llm.py:
#   bedrock  (default) boto3 Converse: production semantics, Guardrails attach
#   openai   any OpenAI-compatible chat-completions endpoint with tool calling
#            (Ollama local, Groq, LiteLLM, vLLM, LM Studio)
WAI_LLM_PROVIDER=bedrock
WAI_LLM_BASE_URL=http://ollama:11434/v1
WAI_LLM_API_KEY=

# -- Option A: Amazon Bedrock (default, highest fidelity) --
# The tool service reads standard AWS env vars (AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN) passed through by docker compose.
AWS_REGION=us-east-1
# Two-tier models (D37). These ids are PLACEHOLDERS - verify against your account:
#   aws bedrock list-inference-profiles --region $AWS_REGION
#   aws bedrock list-foundation-models --by-provider anthropic --region $AWS_REGION
WAI_MODEL_ROUTER=us.anthropic.claude-haiku-4-5-20251001-v1:0
WAI_MODEL_ANALYSIS=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# Optional Bedrock Guardrail (leave empty in the lab; prod attaches per-tenant, D3/D38)
WAI_GUARDRAIL_ID=
WAI_GUARDRAIL_VERSION=DRAFT

# -- Option B: local model via Ollama (fully offline) --
# Validated local demo default: gpt-oss:20b (9/9 golden with lane 0 on).
# Run `make ollama OLLAMA_MODEL=gpt-oss:20b` and `make embed`, then:
# WAI_LLM_PROVIDER=openai
# WAI_LLM_BASE_URL=http://ollama:11434/v1
# WAI_MODEL_ROUTER=gpt-oss:20b
# WAI_MODEL_ANALYSIS=gpt-oss:20b
# Other MoE options (bake-off results vary): qwen2.5:14b, qwen3:30b-a3b

# -- Option C: Groq or any other OpenAI-compatible endpoint --
# Lab demos only: evidence
# transits the provider under ITS terms, not Bedrock's no-retention terms.
# WAI_LLM_PROVIDER=openai
# WAI_LLM_BASE_URL=https://api.groq.com/openai/v1
# WAI_LLM_API_KEY=gsk_your_key_here
# WAI_MODEL_ROUTER=llama-3.3-70b-versatile
# WAI_MODEL_ANALYSIS=llama-3.3-70b-versatile

# -- Option D: split tiers (D39, README s3.4) --
# Each tier may bind to its own provider/endpoint. Empty inherits the
# WAI_LLM_* globals. Two worked examples:
#
# D1 - local router, Bedrock analysis (cuts cost and keeps quality):
# WAI_ROUTER_PROVIDER=openai
# WAI_ROUTER_BASE_URL=http://ollama:11434/v1
# WAI_MODEL_ROUTER=qwen2.5:7b
# WAI_ANALYSIS_PROVIDER=bedrock
# WAI_MODEL_ANALYSIS=us.anthropic.claude-sonnet-4-5-20250929-v1:0
#
# D2 - resident small model for routing, bigger/slower local endpoint for
#      analysis (memory-optimization ladder, incl. a layer-streamed backend):
# WAI_ROUTER_PROVIDER=openai
# WAI_ROUTER_BASE_URL=http://ollama:11434/v1
# WAI_MODEL_ROUTER=qwen2.5:7b
# WAI_ANALYSIS_PROVIDER=openai
# WAI_ANALYSIS_BASE_URL=http://airllm-shim:8090/v1
# WAI_MODEL_ANALYSIS=<huggingface model id served by the shim>

# -- Depth-lane shim (compose profile "airllm", EXPERIMENTAL, README s3.4) --
# Start with `make airllm`. Batch latency by design: 0.07-0.7 tok/s upstream.
# AIRLLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct    # smoke test; the point is 70B+
# AIRLLM_COMPRESSION=4bit                      # 4bit | 8bit | empty
# AIRLLM_MAX_NEW_TOKENS=512
# HF_TOKEN=                                    # for gated models (Llama)

# -- Option E: lane 0 + evidence cache (recommended local demo posture) -----
# `make embed` pulls bge-m3. Enable for 9/9 golden with gpt-oss:20b.
WAI_LANE0_ENABLED=true
WAI_LANE0_THRESHOLD=0.80
WAI_LANE0_NEAR_MISS_FLOOR=0.65
WAI_EMBED_BASE_URL=http://ollama:11434/v1
WAI_EMBED_MODEL=bge-m3
# WAI_EMBED_API_KEY=
# Scope classifier (P1.2): active only when WAI_LANE0_ENABLED=true
# WAI_SCOPE_CLASSIFIER_ENABLED=true
# WAI_SCOPE_MARGIN=0.05
WAI_EVIDENCE_CACHE_TTL=60

# -- Ops knobs (README s8, defaults shown) --
# WAI_STREAMING=true            # token-by-token SSE from the providers
# WAI_QUEUE_WAIT_S=30           # D14: queue for model capacity, then honest 429
# WAI_SERVICE_ENABLED=true      # kill switch: false -> 503 on every surface
# WAI_CONVERSATION_TTL=3600     # in-memory multi-turn window (prod: indexer)
# WAI_MAX_OUTPUT_TOKENS=4096          # raise for tool-heavy MoE models (make evals-qwen3 sets this)
# WAI_EVAL_TIMEOUT_S=600              # host-side golden runner timeout (default 300)
# WAI_INDEXER_CA_PATH=          # pin the wazuh root CA (see the commented mount)

# -- Load balancing / failover proxy (compose profile "litellm", README s3.6) --
# Edit litellm/config.yaml (replicas, fallback groups), start the profile,
# then point a provider (or one tier via option D) at the proxy:
# WAI_LLM_PROVIDER=openai
# WAI_LLM_BASE_URL=http://litellm:4000/v1
# WAI_MODEL_ANALYSIS=analysis-local            # a group name from the config

# ---- Tool service knobs -----------------------------------------------------
WAI_INDEXER_URL=https://wazuh.indexer:9200
WAI_INDEXER_VERIFY_SSL=false
WAI_LANE2_ENABLED=true
WAI_MAX_TOOL_CALLS=6
WAI_EVIDENCE_BUDGET_CHARS=8000

# ---- Ollama / local inference (AMD ROCm default on this harness) --------------
# ROCm image + device passthrough are the compose defaults. For CPU-only or
# NVIDIA hosts, set OLLAMA_IMAGE=ollama/ollama:latest and adjust devices.
# OLLAMA_IMAGE=ollama/ollama:rocm
# OLLAMA_CONTEXT_LENGTH=16384
# Host GIDs for ROCm device access (verify: getent group render video)
# RENDER_GID=105
# VIDEO_GID=44
