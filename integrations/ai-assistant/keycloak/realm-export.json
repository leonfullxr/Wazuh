{
  "realm": "wazuh-poc",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "wazuh_ai_analyst", "description": "May use the wazuh-ai assistant (mirrors the opt-in wazuh_ai_user role, D18)" },
      { "name": "wazuh_ai_operator", "description": "May confirm dashboard-tier wazuh-ai actions (D20)" },
      { "name": "wazuh_ai_responder", "description": "May confirm manager and active-response actions (R6.11)" }
    ]
  },
  "clients": [
    {
      "clientId": "wazuh-ai",
      "name": "wazuh-ai PoC client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    }
  ],
  "users": [
    {
      "username": "analyst1",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Ana",
      "lastName": "Lyst",
      "email": "analyst1@example.test",
      "credentials": [
        { "type": "password", "value": "analyst1", "temporary": false }
      ],
      "realmRoles": ["wazuh_ai_analyst", "wazuh_ai_operator", "wazuh_ai_responder", "default-roles-wazuh-poc"]
    },
    {
      "username": "analyst_no_op",
      "enabled": true,
      "emailVerified": true,
      "firstName": "No",
      "lastName": "Operator",
      "email": "analyst_no_op@example.test",
      "credentials": [
        { "type": "password", "value": "analyst_no_op", "temporary": false }
      ],
      "realmRoles": ["wazuh_ai_analyst", "default-roles-wazuh-poc"]
    },
    {
      "username": "viewer1",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Vera",
      "lastName": "Viewer",
      "email": "viewer1@example.test",
      "credentials": [
        { "type": "password", "value": "viewer1", "temporary": false }
      ],
      "realmRoles": ["default-roles-wazuh-poc"]
    }
  ]
